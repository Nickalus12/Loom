# Neo4j (required — used by memory_engine.py)
NEO4J_PASSWORD="your-secure-password"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"

# LiteLLM Proxy (required — used by memory_engine.py and orchestrator.py)
LITELLM_MASTER_KEY="sk-loom-internal-master"

# Azure AI Foundry Serverless Endpoints (used by litellm_config.yaml heavy tier)
AZURE_FOUNDRY_KEY="your-azure-serverless-key"
AZURE_HEAVY_BASE="https://your-heavy-model.models.ai.azure.com/v1"

# Gemini Embeddings (used by litellm_config.yaml embedding tier)
GEMINI_API_KEY="your-gemini-api-key"

# Local Fallback (used by litellm_config.yaml light tier)
OLLAMA_API_BASE="http://localhost:11434"

# Optional: Override the heavy tier model name (default: heavy/*)
# LOOM_HEAVY_MODEL="heavy/*"

# ── Local Ollama (Gemma 4 E2B) ──────────────────────────────
# Ollama server URL (use localhost for native install, or Docker service name)
OLLAMA_BASE_URL=http://localhost:11434

# Local model names (must be pulled in Ollama first: ollama pull gemma4-e2b)
LOOM_LOCAL_ANALYSIS_MODEL=gemma4-e2b
LOOM_LOCAL_CREATIVE_MODEL=gemma4-e2b

# Background analysis interval in seconds (how often to check for file changes)
LOOM_BACKGROUND_INTERVAL=30
