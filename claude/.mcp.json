{
  "mcpServers": {
    "loom": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/loom-server.js"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    },
    "loom-swarm": {
      "command": "python",
      "args": ["-u", "${CLAUDE_PLUGIN_ROOT}/../scripts/start-swarm.py"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}/..",
      "env": {
        "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}/../src",
        "LOOM_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}/..",
        "PYTHONUNBUFFERED": "1"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  }
}
