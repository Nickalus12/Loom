{
  "mcpServers": {
    "loom": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/loom-server.js"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    },
    "loom-swarm": {
      "command": "python",
      "args": ["-m", "loom.server"],
      "env": {
        "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}/python"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  }
}
